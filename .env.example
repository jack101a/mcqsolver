# SA-Helper Docker deployment environment
# Copy to `.env` and fill values.

SA_HELPER_IMAGE=mcqsolver:local
CONFIG_PATH=./runtime
PUID=1001
PGID=1001
COMPOSE_PROJECT_NAME=mcqsolver

AUTH_HASH_SALT=change-me
ADMIN_TOKEN=change-me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Used by postgres container.
POSTGRES_DB=sa_helper
POSTGRES_USER=sa_helper
POSTGRES_PASSWORD=change-me

DEBUG=false
REDIS_MAXMEMORY=512mb
WORKER_CONCURRENCY=2
QUEUE_WORKERS=2
EXAM_OCR_CONCURRENCY=2

LITELLM_ENDPOINT=http://host.docker.internal:4000
LITELLM_API_KEY=

TELEGRAM_BOT_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
