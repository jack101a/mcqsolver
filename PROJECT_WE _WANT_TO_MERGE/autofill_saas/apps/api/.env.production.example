# Core runtime
PORT=4000
HOST=0.0.0.0
NODE_ENV=production

# Security
JWT_SECRET=replace-with-long-random-secret
BILLING_WEBHOOK_SECRET=replace-with-billing-webhook-secret

# CORS
# Comma separated list. Do not use wildcard in production.
CORS_ALLOW_ORIGINS=https://admin.example.com,https://app.example.com

# Data store
DATA_STORE_BACKEND=postgres
DATABASE_URL=postgres://autofill:autofill@postgres.internal:5432/autofill

# Optional distributed backends
RATE_LIMIT_BACKEND=postgres
EVENT_BUS_BACKEND=postgres
# EVENT_BUS_BACKEND=kafka
# KAFKA_BROKERS=broker1:9092,broker2:9092
# KAFKA_TOPIC=autofill.events
# KAFKA_GROUP_ID=autofill-events-group

# AI mapper provider
AI_MAPPER_BASE_URL=https://ai-mapper.internal
AI_MAPPER_API_KEY=replace-with-ai-mapper-key
AI_MAPPER_TIMEOUT_MS=4500
AI_MAPPER_MAX_RETRIES=2

# CAPTCHA provider
CAPTCHA_PROVIDER_BASE_URL=https://captcha.internal
CAPTCHA_PROVIDER_API_KEY=replace-with-captcha-provider-key
CAPTCHA_PROVIDER_TIMEOUT_MS=4000
CAPTCHA_PROVIDER_MAX_RETRIES=2
