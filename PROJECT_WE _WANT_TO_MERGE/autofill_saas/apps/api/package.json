{
  "name": "@autofill/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "migrate": "node scripts/migrate.mjs",
    "rebuild:incident-metrics": "node scripts/rebuild-incident-metrics.mjs",
    "smoke:integration": "npm run build && node scripts/smoke-integration.mjs",
    "check:security": "node scripts/security-readiness.mjs",
    "dr:preflight": "node scripts/dr-preflight.mjs",
    "dr:restore-drill": "node scripts/dr-restore-drill.mjs",
    "dr:orchestrate": "node scripts/dr-orchestrate.mjs",
    "signoff:release": "node scripts/release-signoff.mjs"
  },
  "dependencies": {
    "@autofill/schemas": "0.1.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^4.28.1",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "pg": "^8.13.1",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
