# Backend runtime env template
# Copy to config/.env for non-docker local backend runs.

# Core auth (must be non-empty in real deployments)
AUTH_HASH_SALT=change_me_random_32_chars
ADMIN_TOKEN=change_me_strong_random_token
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong_password

# Exam service
LITELLM_ENDPOINT=
LITELLM_API_KEY=
# LITELLM_MODEL=gemma-4-31b-it_gemini

# Optional WhatsApp alerts
CALLMEBOT_PHONE=
CALLMEBOT_APIKEY=

# Storage
SQLITE_PATH=backend/logs/app.db

# ONNX model
ONNX_PATH=data/models/model.onnx

# Server
DEBUG=false
RETRAIN_WORKER_ENABLED=false
