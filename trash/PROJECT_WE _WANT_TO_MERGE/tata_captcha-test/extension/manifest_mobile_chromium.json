{
  "manifest_version": 3,
  "name": "AI Task Assistant Mobile (Chromium)",
  "version": "1.0.0",
  "description": "Image/audio/text field automation for Chromium mobile browsers with extension support.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "options_page": "options/options.html",
  "web_accessible_resources": [
    {
      "resources": ["locator_picker.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
